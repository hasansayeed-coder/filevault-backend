generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum FileType {
  IMAGE
  VIDEO
  PDF
  AUDIO
}

enum PackageName {
  FREE
  SILVER
  GOLD
  DIAMOND
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  PENDING
  REFUNDED
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String
  firstName           String
  lastName            String
  role                Role      @default(USER)
  isEmailVerified     Boolean   @default(false)
  emailVerifyToken    String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  isSuspended     Boolean   @default(false)
  suspendedAt     DateTime?
  suspendedReason String?

  subscriptions    UserSubscription[]
  folders          Folder[]
  files            File[]
  stripeCustomerId String?
  fileShares       FileShare[]
  payments         Payment[]

  twoFactorSecret      String?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String[] @default([])
  twoFactorVerified    Boolean  @default(false)

  avatarUrl  String?      
  sessions   UserSession[] 
  activities ActivityLog[]

  @@map("users")
}

model SubscriptionPackage {
  id               String      @id @default(uuid())
  name             PackageName @unique
  displayName      String
  description      String?
  maxFolders       Int
  maxNestingLevel  Int
  allowedFileTypes FileType[]
  maxFileSizeMB    Float
  totalFileLimit   Int
  filesPerFolder   Int
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  userSubscriptions UserSubscription[]
  payments          Payment[]

  @@map("subscription_packages")
}

model UserSubscription {
  id        String    @id @default(uuid())
  userId    String
  packageId String
  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  package SubscriptionPackage @relation(fields: [packageId], references: [id])

  stripeSubscriptionId String?
  stripeCustomerId     String?

  @@index([userId, isActive])

  @@map("user_subscriptions")
}

model Folder {
  id           String   @id @default(uuid())
  name         String
  userId       String
  parentId     String?
  nestingLevel Int      @default(0)
  isStarred    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     Folder?  @relation("FolderToSubfolders", fields: [parentId], references: [id], onDelete: Cascade)
  subfolders Folder[] @relation("FolderToSubfolders")
  files      File[]

  @@index([userId, parentId])

  @@map("folders")
}

model File {
  id           String   @id @default(uuid())
  name         String
  originalName String
  mimeType     String
  fileType     FileType
  size         Float
  path         String
  folderId     String
  userId       String
  isStarred    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  folder   Folder      @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares   FileShare[]
  versions FileVersion[]
  deletedAt    DateTime?   
  trashedAt    DateTime?   // same as deletedAt, used for 30-day auto-purge

  @@index([userId, deletedAt])
  @@index([folderId, deletedAt])
  @@index([fileType])

  @@map("files")
}

model FileShare {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  fileId      String
  userId      String
  expiresAt   DateTime?
  password    String?
  accessCount Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("file_shares")
}

model FileVersion {
  id            String   @id @default(uuid())
  fileId        String
  versionNumber Int
  name          String
  originalName  String
  mimeType      String
  fileType      FileType
  size          Float
  path          String
  createdAt     DateTime @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("file_versions")
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  packageId       String
  stripeSessionId String        @unique
  stripePaymentId String?
  amount          Float
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  package SubscriptionPackage @relation(fields: [packageId], references: [id])

  @@index([userId, createdAt(sort: Desc)])


  @@map("payments")
}


model UserSession {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  deviceInfo String?
  ipAddress  String?
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

enum ActivityAction {
  LOGIN
  LOGOUT
  REGISTER
  LOGIN_FAILED
  PASSWORD_CHANGED
  EMAIL_CHANGED
  TWO_FA_ENABLED
  TWO_FA_DISABLED
  FILE_UPLOAD
  FILE_DELETE
  FILE_RESTORE
  FILE_PERMANENT_DELETE
  FILE_RENAME
  FILE_MOVE
  FILE_DOWNLOAD
  FILE_STAR
  FILE_UNSTAR
  FOLDER_CREATE
  FOLDER_DELETE
  FOLDER_RENAME
  TRASH_EMPTIED
  ACCOUNT_SUSPENDED
  ACCOUNT_UNSUSPENDED
  PASSWORD_RESET_ADMIN
}

model ActivityLog {
  id         String         @id @default(uuid())
  userId     String
  action     ActivityAction
  entityType String?
  entityId   String?
  entityName String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action])
  @@map("activity_logs")
}




